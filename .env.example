# ─── Backend (set these as Environment Variables on Render) ───────────────────

# Neon JDBC URL — copy from Neon dashboard > Connection Details > JDBC
DATABASE_URL=jdbc:postgresql://<host>/<dbname>?sslmode=require

# Neon DB credentials
DB_USERNAME=<neon_user>
DB_PASSWORD=<neon_password>

# Port (Render sets this automatically; 8081 is used locally)
PORT=8081

# Comma-separated list of allowed frontend origins
# Set to your Vercel deployment URL after deploying
ALLOWED_ORIGINS=https://your-app.vercel.app

# ─── Frontend (set these as Environment Variables on Vercel) ──────────────────

# Full URL to your Render backend, including /api
VITE_API_BASE_URL=https://your-backend.onrender.com/api
